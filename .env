PORT=4000
NODE_ENV=production

# ─── قاعدة البيانات (PostgreSQL) ───
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atheer_switch
DB_USER=postgres
DB_PASS=postgres
DB_SSL=false

# ─── Redis ───
REDIS_HOST=localhost
REDIS_PORT=6379

# ─── الأمان ───
JWT_SECRET=AtheerSuperSecretKey2026!!
API_KEY_HEADER=x-atheer-api-key
WALLET_MERCHANT_API_KEY=AtheerSecretKey2026!
ADMIN_API_KEY=AtheerAdminKey2026!!

# ─── التشفير (حرج — لا تشاركه أبداً) ───
# توليد: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
DEVICE_MASTER_SEED=a1b2c3d4e5f60718293a4b5c6d7e8f90a1b2c3d4e5f60718293a4b5c6d7e8f90

# ─── مزود الدفع (جوالي) ───
JAWALI_API_URL=http://206.189.137.59:3001/api/v1
JAWALI_AGENT_WALLET=888888888
