# إعدادات الخادم
PORT=3000
NODE_ENV=development

# إعدادات قاعدة البيانات (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=atheer_switch
DB_USER=postgres
DB_PASS=postgres

# إعدادات التخزين المؤقت (Redis)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASS=

# إعدادات مزودي الخدمة (Jawali/WeCash)
JAWALI_API_URL=https://api.jawali.com/v1
JAWALI_AGENT_WALLET=YOUR_WALLET_ID
JAWALI_API_KEY=YOUR_API_KEY

# إعدادات الأمان
JWT_SECRET=YOUR_SUPER_SECRET_KEY
API_KEY_HEADER=x-atheer-api-key
