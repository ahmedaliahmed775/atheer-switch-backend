# خادم
PORT=3000
NODE_ENV=development

# PostgreSQL — يدعم أيضاً DATABASE_URL (كسلسلة اتصال واحدة)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=atheer_switch
DB_USER=postgres
# كلمة المرور: يُقبل DB_PASS أو DB_PASSWORD (متوافق مع DigitalOcean)
DB_PASS=postgres
# للاتصال بـ PostgreSQL المُدار (DigitalOcean): عيّن DB_SSL=true
DB_SSL=false
# DATABASE_URL=
# DB_SSL_REJECT_UNAUTHORIZED=false

# Redis — أو استخدم REDIS_URL فقط (مثل rediss://... على المنصات المُدارة)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=
# REDIS_URL=
# للـ Redis مع TLS (مثل DigitalOcean Managed Redis): REDIS_TLS=true
REDIS_TLS=false

# مزودو الدفع
JAWALI_API_URL=https://api.jawali.com/v1
JAWALI_AGENT_WALLET=YOUR_WALLET_ID
JAWALI_API_KEY=YOUR_API_KEY

# أمان
JWT_SECRET=YOUR_SUPER_SECRET_KEY
API_KEY_HEADER=x-atheer-api-key

# محرك التحقق عديم الحالة — Anti-Replay Verification Engine
# يجب أن يكون hex string طوله 64 حرفاً (32 بايت)
# يُستخدم لاشتقاق seeds الأجهزة وإعادة بناء مفاتيح LUK
DEVICE_MASTER_SEED=replace_with_64_hex_chars_random_secret

# الإنتاج: مسارات /api/v1/admin تتطلب الترويسة x-atheer-admin-key
ADMIN_API_KEY=generate_a_long_random_secret_at_least_16_chars
